# ===== 后端 =====
# SQLite 库文件路径(后端用 sqlite3 直连,读 DB_PATH;留空则默认 storage/app.db)
DB_PATH=./storage/app.db
STORAGE_DIR=./storage
PREGEN_DIR=./pregenerated
# 生成模式:auto(先实时失败回落)| cached(直接预生成池,demo 现场)| live(只实时)
GENERATION_MODE=auto
# 前端 CORS 来源(逗号分隔)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== AI 引擎(切换部署只改这一行)=====
# Mac/cloudflared 或 pod 的公网 URL;Colab 临时 URL 也填这里
ACESTEP_BASE_URL=https://xxxx.trycloudflare.com
ACESTEP_API_KEY=

# ===== LLM(标题/墓志铭/prompt/歌词)=====
LLM_API_KEY=

# ===== 文生图(可选,精修配图)=====
IMAGE_API_KEY=
